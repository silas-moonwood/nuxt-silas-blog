{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["node_modules", "dist", "public", "build", ".nuxt/**/*", ".output/**/*"],
  "semi": false,
  "singleQuote": true,
  "jsxSingleQuote": true,
  "trailingComma": "none",
  "sortImports": true,
  "sortTailwindcss": true,
  "jsdoc": true
  // "bracketSameLine": true,
  // "arrowParens": "avoid"
}
